*.rkt~
*.rkt.bak
\#*.rkt#
\#*.rkt#*#

# Compiled racket bytecode
compiled/
*.zo

# Dependency tracking files
*.dep

# Bun/TypeScript migration scaffold
node_modules/
dist/
.chrysalis/
.vite/
.codex
.sprite
bun.lock
data/
