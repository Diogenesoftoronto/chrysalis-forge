Output .vhs/tool-evolution.mp4
Set FontSize 14
Set Width 1200
Set Height 600
Set Theme "catppuccin-mocha"
Set Shell "bash"

# Tool Evolution: Show how tools can be evolved at runtime
Type 'chrysalis shell'
Enter
Sleep 2s

# Show help with evolve-tool command visible
Type '/help'
Enter
Sleep 3s

# Show profile setting with NL
Type '/profile make it fast and cheap'
Enter
Sleep 1s

# Show stats to see evolution state
Type '/stats'
Enter
Sleep 2s

# Exit
Type '/exit'
Enter
Sleep 1s
